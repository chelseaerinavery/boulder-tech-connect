---
export interface Props {
  title?: string;
  description?: string;
  /** Path to a social share image in /public, e.g. "/og-image.png" (1200x630). */
  ogImage?: string;
}

const {
  title = "Boulder Tech Connect | Tech Networking Meetup in Boulder, CO",
  description = "Boulder, Colorado's casual tech networking meetup.",
  ogImage,
} = Astro.props;

// Keywords the page targets (low ranking weight, but harmless + used by some engines).
const keywords =
  "Boulder tech meetup, Boulder networking, tech networking, Boulder tech jobs, tech hiring, developer meetup, Boulder tech community, tech events Boulder, Front Range tech meetup, Colorado Front Range tech networking";

// Canonical + absolute OG URL derived from `site` in astro.config.mjs
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site) : undefined;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload the full-screen background (the LCP element) so it paints sooner -->
    <link rel="preload" as="image" href="/bg-mobile.png" media="(max-width: 767px)" />
    <link rel="preload" as="image" href="/bg-desktop.png" media="(min-width: 768px)" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#c1bdf4" />

    <!-- Local SEO (Boulder / Colorado Front Range) -->
    <meta name="geo.region" content="US-CO" />
    <meta name="geo.placename" content="Boulder, Colorado" />
    <meta name="geo.position" content="40.029616;-105.259456" />
    <meta name="ICBM" content="40.029616, -105.259456" />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Boulder Tech Connect" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    {ogImageUrl && (
      <meta
        property="og:image:alt"
        content="A crowded Boulder tech event with a Boulder Tech Connect slide on the big screen"
      />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data: helps search engines understand the org + the recurring meetup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${canonical.origin}/#org`,
          "name": "Boulder Tech Connect",
          "description": description,
          "url": canonical.origin,
          "foundingDate": "2024",
          "keywords": keywords,
          "areaServed": [
            { "@type": "City", "name": "Boulder, Colorado" },
            { "@type": "AdministrativeArea", "name": "Colorado Front Range" }
          ],
          "knowsAbout": [
            "Technology networking",
            "Software development",
            "Startups",
            "Tech jobs and hiring"
          ],
          "sameAs": [
            "https://luma.com/boulder-tech-connect",
            "https://www.meetup.com/boulder-tech-connect/"
          ],
          "location": {
            "@type": "Place",
            "name": "Rayback Collective",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "2775 Valmont Rd",
              "addressLocality": "Boulder",
              "addressRegion": "CO",
              "postalCode": "80304",
              "addressCountry": "US"
            }
          }
        },
        {
          "@type": "Event",
          "name": "Boulder Tech Connect Monthly Meetup",
          "description": "A casual monthly tech networking meetup on the Colorado Front Range. Developers, designers, founders, recruiters, and job seekers gather to network over drinks.",
          "eventSchedule": {
            "@type": "Schedule",
            "byDay": "https://schema.org/Wednesday",
            "repeatFrequency": "P1M",
            "startTime": "18:00",
            "endTime": "20:00"
          },
          "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
          "organizer": { "@id": `${canonical.origin}/#org` },
          "location": {
            "@type": "Place",
            "name": "Rayback Collective",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "2775 Valmont Rd",
              "addressLocality": "Boulder",
              "addressRegion": "CO",
              "postalCode": "80304",
              "addressCountry": "US"
            }
          }
        }
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
