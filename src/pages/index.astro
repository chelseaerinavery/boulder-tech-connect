---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

// Events are loaded live in the browser from /api/events (a Netlify function
// that reads Luma's iCal feed), so they're always current with no rebuilds.
const CAL_URL = "https://luma.com/boulder-tech-connect";
---

<Layout ogImage="/og-image.jpg">
  <header class="site-header">
    <h1 class="brand">Boulder Tech Connect</h1>
    <p class="tagline">boulder's casual tech networking meetup</p>
    <nav>
      <ul>
        <li><a href="#gallery">Photos</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#connect">Connect</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section id="events" class="events">
      <h2>Upcoming Events</h2>
      <ul
        class="event-list"
        id="event-list"
        aria-live="polite"
        aria-busy="true"
      >
        <li class="events-status">Loading events…</li>
      </ul>
      <noscript>
        <p class="events-status">
          <a href={CAL_URL} target="_blank" rel="noopener">
            View upcoming events on Luma →
          </a>
        </p>
      </noscript>
    </section>

    <script>
      const CAL_URL = "https://luma.com/boulder-tech-connect";
      const TZ = "America/Denver";
      const fmt = (d: Date, opts: Intl.DateTimeFormatOptions) =>
        new Intl.DateTimeFormat("en-US", { timeZone: TZ, ...opts }).format(d);

      // YYYY-MM-DD in Boulder's timezone, for comparing calendar days
      const dayKey = (d: Date) =>
        new Intl.DateTimeFormat("en-CA", {
          timeZone: TZ,
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
        }).format(d);

      type ApiEvent = {
        title: string;
        start: string;
        end: string | null;
        location: string;
        url: string | null;
        host: string | null;
        hostUrl: string | null;
      };

      function renderCard(ev: ApiEvent): HTMLLIElement {
        const start = new Date(ev.start);
        const li = document.createElement("li");
        li.className = "event-card";

        const date = document.createElement("div");
        date.className = "event-date";
        date.setAttribute("aria-hidden", "true");
        const month = document.createElement("span");
        month.className = "event-month";
        month.textContent = fmt(start, { month: "short" });
        const day = document.createElement("span");
        day.className = "event-day";
        day.textContent = fmt(start, { day: "numeric" });
        date.append(month, day);

        const body = document.createElement("div");
        body.className = "event-body";

        const title = document.createElement("h3");
        title.className = "event-title";
        const link = document.createElement("a");
        link.href = ev.url || CAL_URL;
        link.target = "_blank";
        link.rel = "noopener";
        link.textContent = ev.title;
        title.append(link);

        const meta = document.createElement("p");
        meta.className = "event-meta";
        const time = document.createElement("time");
        time.dateTime = ev.start;
        time.textContent = `${fmt(start, { weekday: "long" })} · ${fmt(start, {
          hour: "numeric",
          minute: "2-digit",
          timeZoneName: "short",
        })}`;
        meta.append(time);

        body.append(title);

        if (ev.host) {
          const host = document.createElement("p");
          host.className = "event-host";
          host.append(document.createTextNode("Hosted by "));
          if (ev.hostUrl) {
            const hostLink = document.createElement("a");
            hostLink.href = ev.hostUrl;
            hostLink.target = "_blank";
            hostLink.rel = "noopener";
            hostLink.textContent = ev.host;
            host.append(hostLink);
          } else {
            host.append(document.createTextNode(ev.host));
          }
          body.append(host);
        }

        body.append(meta);

        if (ev.location) {
          const loc = document.createElement("p");
          loc.className = "event-location";
          // Just the place name — the full address is in the Luma event
          loc.textContent = ev.location.split(",")[0];
          body.append(loc);
        }

        li.append(date, body);

        // Events run by other communities on our calendar get a spotlight sticker
        if (ev.host && ev.host !== "Boulder Tech Connect") {
          const sticker = document.createElement("img");
          sticker.className = "event-spotlight";
          sticker.src = "/community-spotlight.png";
          sticker.alt = "Community spotlight";
          sticker.width = 210;
          sticker.height = 168;
          li.append(sticker);
        }

        // If the event happens today (Boulder time), flag the card and add the badge
        if (dayKey(start) === dayKey(new Date())) {
          li.classList.add("is-today");
          const badge = document.createElement("img");
          badge.className = "event-today";
          badge.src = "/today.png";
          badge.alt = "Happening today";
          badge.width = 96;
          badge.height = 96;
          li.append(badge);
        }

        return li;
      }

      // Inject Event structured data for the live events so search engines can
      // show them as rich results. Google indexes JS-injected JSON-LD.
      function injectEventSchema(events: ApiEvent[]) {
        const schema = {
          "@context": "https://schema.org",
          "@type": "ItemList",
          itemListElement: events.map((ev, i) => ({
            "@type": "ListItem",
            position: i + 1,
            item: {
              "@type": "Event",
              name: ev.title,
              startDate: ev.start,
              ...(ev.end ? { endDate: ev.end } : {}),
              eventAttendanceMode:
                "https://schema.org/OfflineEventAttendanceMode",
              eventStatus: "https://schema.org/EventScheduled",
              ...(ev.location
                ? {
                    location: {
                      "@type": "Place",
                      name: ev.location.split(",")[0],
                      address: ev.location,
                    },
                  }
                : {}),
              ...(ev.host
                ? {
                    organizer: {
                      "@type": "Organization",
                      name: ev.host,
                      ...(ev.hostUrl ? { url: ev.hostUrl } : {}),
                    },
                  }
                : {}),
              ...(ev.url ? { url: ev.url } : {}),
            },
          })),
        };
        const script = document.createElement("script");
        script.type = "application/ld+json";
        script.textContent = JSON.stringify(schema);
        document.head.append(script);
      }

      function statusMessage(text: string, linkText: string): HTMLLIElement {
        const li = document.createElement("li");
        li.className = "events-status";
        li.append(document.createTextNode(text + " "));
        const a = document.createElement("a");
        a.href = CAL_URL;
        a.target = "_blank";
        a.rel = "noopener";
        a.textContent = linkText;
        li.append(a);
        return li;
      }

      async function loadEvents() {
        const list = document.getElementById("event-list");
        if (!list) return;
        try {
          const res = await fetch("/api/events");
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const { events } = (await res.json()) as { events: ApiEvent[] };
          list.replaceChildren();
          if (!events || events.length === 0) {
            list.append(
              statusMessage(
                "No upcoming events are posted right now.",
                "Check the Luma calendar →",
              ),
            );
          } else {
            for (const ev of events) list.append(renderCard(ev));
            injectEventSchema(events);
          }
        } catch (err) {
          list.replaceChildren(
            statusMessage(
              "Couldn’t load events right now.",
              "View them on Luma →",
            ),
          );
        } finally {
          list.setAttribute("aria-busy", "false");
        }
      }

      loadEvents();
    </script>

    <section id="gallery" class="gallery">
      <h2>Share your photos!</h2>
      <div class="grid">
        <img
          src="/gallery/meetup-1.jpg"
          alt="Boulder Tech Connect attendees mingling at a past meetup"
          loading="lazy"
          width="800"
          height="600"
        />
        <img
          src="/gallery/meetup-2.jpg"
          alt="The crowd at a recent Boulder Tech Connect gathering"
          loading="lazy"
          width="800"
          height="600"
        />
        <img
          src="/gallery/meetup-3.jpg"
          alt="A speaker addressing the crowd on stage at a Boulder Tech Connect networking meetup"
          loading="lazy"
          width="640"
          height="480"
        />
        <img
          src="/gallery/meetup-4.jpg"
          alt="Tech professionals networking at a Boulder Tech Connect monthly happy hour at a Boulder brewery"
          loading="lazy"
          width="1600"
          height="1200"
        />
      </div>
    </section>

    <section class="info card">
      <div id="about" class="about">
        <h2>About</h2>
        <p>
          Boulder Tech Connect is a casual tech networking meetup that brings
          together developers, designers, founders, recruiters, and anyone
          working in tech across Boulder and the Colorado Front Range. Whether
          you're new in town, job hunting, hiring, or a longtime local, come
          grab a drink and meet your neighbors in tech.
        </p>
        <p>
          It's a relaxed way to network, swap ideas, hear who's hiring, and find
          your next tech job or teammate. We typically meet on the
          <strong>first Wednesday of every month</strong> at <a
            href="https://maps.google.com/?q=Rayback+Collective+Boulder"
            target="_blank"
            rel="noopener">Rayback Collective</a
          >, Boulder's food-truck beer garden on Valmont. No agenda, just grab a
          name tag and say hi.
        </p>
      </div>

      <hr class="divider" />

      <div id="connect" class="connect">
        <h2>Stay Connected</h2>
        <p class="section-intro">
          Follow us to get notified about each month's meetup.
        </p>
        <div class="links">
          <a
            href="https://luma.com/boulder-tech-connect"
            target="_blank"
            rel="noopener">Luma</a
          >
          <a
            href="https://www.meetup.com/boulder-tech-connect/"
            target="_blank"
            rel="noopener">Meetup</a
          >
        </div>
      </div>
    </section>
  </main>

  <footer>
    <p>&copy; 2026 Boulder Tech Connect</p>
  </footer>
</Layout>
